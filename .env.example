# Anthropic API key for Claude calls (query generation, extraction, validation)
ANTHROPIC_API_KEY=

# Nimble API key for web search and extraction
NIMBLE_API_KEY=

# Supabase project (leave blank and use --dry-run for local testing)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: DEBUG for verbose logs
LOG_LEVEL=INFO
